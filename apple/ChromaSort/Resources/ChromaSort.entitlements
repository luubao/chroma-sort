<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Required for the Mac App Store. Applied only to the Catalyst (macosx)
	     SDK — see project.yml. The game is fully offline, so it needs no
	     network, file, or device entitlements. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
</dict>
</plist>
